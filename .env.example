# Your Solana wallet address (used by test_meteora.py)
WALLET_ADDRESS=YourWalletAddressHere

# Position addresses to test (comma-separated, used by test_meteora.py)
TEST_POSITIONS=addr1,addr2,addr3

# Optional: Helius RPC URL for faster address resolution
# RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# LpAgent API credentials (used by valhalla/lpagent_client.py)
LPAGENT_API_KEY=your_lpagent_api_key_here
# Optional: override the default wallet address for LpAgent queries
# LPAGENT_WALLET=J4tkGDbTUVtAkcziKruadhRkP3A9HquvmBXK6bsSVArF
